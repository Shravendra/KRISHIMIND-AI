# ─────────────────────────────────────────────
#  KrishiMind-AI  Environment Configuration
# ─────────────────────────────────────────────

# App
APP_ENV=dev                          # dev | staging | production
APP_NAME=KrishiMind-AI
APP_VERSION=0.1.0
SECRET_KEY=change-me-to-a-strong-secret-key-64chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API Gateway
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM (via LiteLLM)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
DEFAULT_LLM=openai/gpt-4o-mini     # cheap default; override per-agent
VISION_LLM=openai/gpt-4o
REASONING_LLM=anthropic/claude-3-5-sonnet-20241022

# Redis
REDIS_URL=redis://localhost:6379/0

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=krishimind_kb

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://krishimind:password@localhost:5432/krishimind_db

# Object Storage (MinIO / S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=krishimind-images
MINIO_SECURE=false

# Weather API (OpenWeatherMap)
OPENWEATHER_API_KEY=your-key-here

# Market Data
AGMARKET_API_KEY=your-key-here

# MCP
MCP_TOKEN_SECRET=mcp-secret-token-here

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=INFO
